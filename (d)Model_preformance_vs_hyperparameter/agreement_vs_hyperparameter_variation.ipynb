      "cell_type": "code",
      "source": [
        "# !pip install openai --quiet\n",
        "import re, time, json, numpy as np, pandas as pd, os\n",
        "from openai import OpenAI\n",
        "\n",
        "# ========= 0) SETTINGS =========\n",
        "OPENAI_API_KEY = \"sk"  # <-- put your key\n",
        "MODEL = \"gpt-4o-mini\"  # cheap & good; change if you like\n",
        "\n",
        "client = OpenAI(api_key=OPENAI_API_KEY)\n",
        "\n",
        "# ========= 1) PREPARE: normalize keys and join =========\n",
        "def norm_txt(x):\n",
        "    if x is None or (isinstance(x,float) and np.isnan(x)): return \"\"\n",
        "    return str(x).strip().upper()\n",
        "\n",
        "def norm_id(x):\n",
        "    s = str(x).strip()\n",
        "    s = re.sub(r\"\\.0$\", \"\", s)     # drop .0\n",
        "    s = re.sub(r\"[^\\d]\", \"\", s)    # keep digits only\n",
        "    return s\n",
        "\n",
        "hum = human_narratives_df.copy()\n",
        "hum[\"case_id_key\"] = hum[\"case_id\"].map(norm_id)\n",
        "hum[\"drug_key\"]    = hum[\"drug\"].map(norm_txt)\n",
        "hum[\"event_key\"]   = hum[\"event\"].map(norm_txt)\n",
        "\n",
        "llm = df2.copy()\n",
        "llm[\"case_id_key\"] = llm[\"case_id\"].map(norm_id)\n",
        "llm[\"drug_key\"]    = llm[\"drug\"].map(norm_txt)\n",
        "llm[\"event_key\"]   = llm[\"event\"].map(norm_txt)\n",
        "\n",
        "pairs = pd.merge(\n",
        "    hum[[\"case_id\",\"drug\",\"event\",\"case_id_key\",\"drug_key\",\"event_key\",\"narrative\"]],\n",
        "    llm[[\"case_id\",\"drug\",\"event\",\"case_id_key\",\"drug_key\",\"event_key\",\n",
        "         \"temperature\",\"frequency_penalty\",\"max_new_token\",\"llm_output\"]],\n",
        "    on=[\"case_id_key\",\"drug_key\",\"event_key\"],\n",
        "    how=\"inner\",\n",
        "    suffixes=(\"_human\",\"_llm\")\n",
        ")\n",
        "\n",
        "print(f\"✅ Pairs ready: {len(pairs)}\")\n",
        "\n",
        "# ========= 2) OpenAI call: strict JSON =========\n",
        "JSON_SCHEMA = {\n",
        "  \"name\": \"naranjo_agreement\",\n",
        "  \"schema\": {\n",
        "    \"type\": \"object\",\n",
        "    \"properties\": {\n",
        "      \"agree_q1\":  {\"type\":\"boolean\"},\n",
        "      \"agree_q2\":  {\"type\":\"boolean\"},\n",
        "      \"agree_q3\":  {\"type\":\"boolean\"},\n",
        "      \"agree_q4\":  {\"type\":\"boolean\"},\n",
        "      \"agree_q5\":  {\"type\":\"boolean\"},\n",
        "      \"agree_q6\":  {\"type\":\"boolean\"},\n",
        "      \"agree_q7\":  {\"type\":\"boolean\"},\n",
        "      \"agree_q8\":  {\"type\":\"boolean\"},\n",
        "      \"agree_q9\":  {\"type\":\"boolean\"},\n",
        "      \"agree_q10\": {\"type\":\"boolean\"},\n",
        "      \"notes\": {\"type\":\"string\", \"description\":\"Short justification of any disagreements (optional).\"}\n",
        "    },\n",
        "    \"required\": [\"agree_q1\",\"agree_q2\",\"agree_q3\",\"agree_q4\",\"agree_q5\",\"agree_q6\",\"agree_q7\",\"agree_q8\",\"agree_q9\",\"agree_q10\"],\n",
        "    \"additionalProperties\": False\n",
        "  }\n",
        "}\n",
        "\n",
        "SYSTEM_PROMPT = (\n",
        "    \"You are an evaluator. Compare two Naranjo-style narratives (human vs. LLM). \"\n",
        "    \"First extract Q1..Q10 from each narrative even if formats differ. \"\n",
        "    \"For each question i, mark agree_qi = true if the FINAL stance/score/rationale meaning matches, \"\n",
        "    \"else false. Ignore wording; judge semantic equivalence. Return ONLY JSON (no prose).\"\n",
        ")\n",
        "\n",
        "def compare_one(human_text: str, llm_text: str) -> dict:\n",
        "    fallback = {f\"agree_q{i}\": False for i in range(1,11)}\n",
        "    fallback[\"notes\"] = \"fallback\"\n",
        "    try:\n",
        "        msg = [\n",
        "            {\"role\":\"system\",\"content\": SYSTEM_PROMPT},\n",
        "            {\"role\":\"user\",\"content\": (\n",
        "                \"HUMAN NARRATIVE:\\n\"\n",
        "                f\"{human_text}\\n\\n\"\n",
        "                \"LLM NARRATIVE:\\n\"\n",
        "                f\"{llm_text}\\n\"\n",
        "                \"Return JSON with agree_q1..agree_q10 booleans.\"\n",
        "            )}\n",
        "        ]\n",
        "        resp = client.chat.completions.create(\n",
        "            model=MODEL,\n",
        "            messages=msg,\n",
        "            response_format={\"type\":\"json_schema\",\"json_schema\":JSON_SCHEMA},\n",
        "            temperature=0\n",
        "        )\n",
        "        content = resp.choices[0].message.content\n",
        "        data = json.loads(content)\n",
        "        for i in range(1,11):\n",
        "            data.setdefault(f\"agree_q{i}\", False)\n",
        "        data.setdefault(\"notes\",\"\")\n",
        "        return data\n",
        "    except Exception as e:\n",
        "        print(\"⚠️ OpenAI error, using fallback:\", e)\n",
        "        return fallback\n",
        "\n",
        "# ========= 3) Run evaluation over pairs with incremental save =========\n",
        "output_file = \"agreement_progress.csv\"\n",
        "\n",
        "# Resume previous progress if exists\n",
        "if os.path.exists(output_file):\n",
        "    agreement_df = pd.read_csv(output_file)\n",
        "    processed_ids = set(agreement_df[\"case_id\"].astype(str))\n",
        "    print(f\"Resuming from saved progress, {len(processed_ids)} cases already done.\")\n",
        "else:\n",
        "    agreement_df = pd.DataFrame()\n",
        "    processed_ids = set()\n",
        "    print(\"Starting fresh evaluation.\")\n",
        "\n",
        "for idx, r in pairs.iterrows():\n",
        "    case_id = str(r[\"case_id_human\"])\n",
        "    if case_id in processed_ids:\n",
        "        continue  # skip already processed\n",
        "\n",
        "    comp = compare_one(r[\"narrative\"], r[\"llm_output\"])\n",
        "    flags = [int(comp[f\"agree_q{i}\"]) for i in range(1,11)]\n",
        "    avg = float(np.mean(flags)) if flags else 0.0\n",
        "\n",
        "    result_row = {\n",
        "        \"case_id\": case_id,\n",
        "        \"drug\":    r[\"drug_human\"],\n",
        "        \"event\":   r[\"event_human\"],\n",
        "        \"agree_q1\":  comp[\"agree_q1\"],\n",
        "        \"agree_q2\":  comp[\"agree_q2\"],\n",
        "        \"agree_q3\":  comp[\"agree_q3\"],\n",
        "        \"agree_q4\":  comp[\"agree_q4\"],\n",
        "        \"agree_q5\":  comp[\"agree_q5\"],\n",
        "        \"agree_q6\":  comp[\"agree_q6\"],\n",
        "        \"agree_q7\":  comp[\"agree_q7\"],\n",
        "        \"agree_q8\":  comp[\"agree_q8\"],\n",
        "        \"agree_q9\":  comp[\"agree_q9\"],\n",
        "        \"agree_q10\": comp[\"agree_q10\"],\n",
        "        \"question_agreement_rate\": round(avg, 3),\n",
        "        \"temperature\":        r[\"temperature\"],\n",
        "        \"frequency_penalty\":  r[\"frequency_penalty\"],\n",
        "        \"max_new_token\":     r[\"max_new_token\"],\n",
        "        \"notes\":              comp.get(\"notes\",\"\")\n",
        "    }\n",
        "\n",
        "    agreement_df = pd.concat([agreement_df, pd.DataFrame([result_row])], ignore_index=True)\n",
        "\n",
        "    # Save progress\n",
        "    agreement_df.to_csv(output_file, index=False)\n",
        "\n",
        "    print(f\"✅ Processed case {case_id} ({idx+1}/{len(pairs)})\")\n",
        "\n",
        "print(\"✅ Evaluation complete!\")\n",
        "print(\"Final DataFrame shape:\", agreement_df.shape)"
      ],
