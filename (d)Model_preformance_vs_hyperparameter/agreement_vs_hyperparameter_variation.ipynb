      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "# --- 0) Prepare DataFrame and normalize case_id ---\n",
        "df = df.copy()  # assume df is already loaded\n",
        "df[\"case_id_str\"] = df[\"case_id\"].astype(str).str.replace(r\"\\.0$\", \"\", regex=True).str.strip()\n",
        "\n",
        "# Use all rows (no filtering)\n",
        "df_sel = df.copy()\n",
        "found_ids = sorted(df_sel[\"case_id_str\"].unique().tolist())\n",
        "print(f\"✅ Selected rows: {len(df_sel)}\")\n",
        "print(f\"✅ Found {len(found_ids)} unique case_ids\")\n",
        "\n",
        "# --- 1) Define Naranjo questions ---\n",
        "NARANJO_QUESTIONS = {\n",
        "    1: \"Are there previous conclusive reports on this reaction?\",\n",
        "    2: \"Did the adverse event appear after the suspected drug was administered?\",\n",
        "    3: \"Did the adverse reaction improve when the drug was discontinued or a specific antagonist was administered?\",\n",
        "    4: \"Did the adverse reaction reappear when the drug was readministered?\",\n",
        "    5: \"Are there alternative causes that could have caused the reaction?\",\n",
        "    6: \"Did the reaction reappear when a placebo was given?\",\n",
        "    7: \"Was the drug detected in blood (or other fluids) in concentrations known to be toxic?\",\n",
        "    8: \"Was the reaction more severe when the dose was increased, or less severe when the dose was decreased?\",\n",
        "    9: \"Did the patient have a similar reaction to the same or similar drugs in any previous exposure?\",\n",
        "    10:\"Was the adverse event confirmed by any objective evidence?\"\n",
        "}\n",
        "\n",
        "# --- 2) Helper functions ---\n",
        "def _safe(val, fallback=\"No information provided.\"):\n",
        "    if val is None: return fallback\n",
        "    if isinstance(val, float) and np.isnan(val): return fallback\n",
        "    s = str(val).strip()\n",
        "    return s if s else fallback\n",
        "\n",
        "def _safe_score(val):\n",
        "    try:\n",
        "        if val is None or (isinstance(val, float) and np.isnan(val)):\n",
        "            return 0\n",
        "        return int(val)\n",
        "    except Exception:\n",
        "        try:\n",
        "            return int(str(val).replace('+','').strip())\n",
        "        except Exception:\n",
        "            return 0\n",
        "\n",
        "def interpret_naranjo(total):\n",
        "    if total >= 9: return \"Definite\"\n",
        "    if 5 <= total <= 8: return \"Probable\"\n",
        "    if 1 <= total <= 4: return \"Possible\"\n",
        "    return \"Doubtful\"\n",
        "\n",
        "# --- 3) Build narrative for a row ---\n",
        "def build_narrative_row(row):\n",
        "    case_id = _safe(row.get('case_id'))\n",
        "    drug    = _safe(row.get('drug_name', 'Unknown drug'))\n",
        "    event   = _safe(row.get('pt', 'Unknown event'))\n",
        "\n",
        "    parts, total_from_items = [], 0\n",
        "    for i in range(1, 11):\n",
        "        q_text = NARANJO_QUESTIONS[i]\n",
        "        score  = _safe_score(row.get(f\"q{i}_score\", 0))\n",
        "        reason = _safe(row.get(f\"q{i}_reasoning\"))\n",
        "        total_from_items += score\n",
        "        parts.append(\n",
        "            f\"{i}. {q_text}\\n\"\n",
        "            f\"   Score: {score}\\n\"\n",
        "            f\"   Reasoning: {reason}\\n\"\n",
        "        )\n",
        "\n",
        "    total_score = total_from_items\n",
        "    interpretation = interpret_naranjo(total_score)\n",
        "\n",
        "    # Header with LLM guidance\n",
        "    header = (\n",
        "        f\"Based on the provided case information and the Naranjo algorithm scoring details, \"\n",
        "        f\"here is the assessment for {drug} causing {event} (Case ID: {case_id}):\\n\\n\"\n",
        "        f\"Naranjo Algorithm Questions and Scores:\\n\\n\"\n",
        "        f\"⚠️ Instructions for the LLM:\\n\"\n",
        "        f\"- Do NOT mark scores as incorrect if they are equivalent in meaning.\\n\"\n",
        "        f\"  Example: a table value of 1 is equivalent to '+1'.\\n\"\n",
        "        f\"- Focus only on reasoning and interpretation of the scores.\\n\\n\"\n",
        "    )\n",
        "\n",
        "    body = \"\\n\".join(parts)\n",
        "    total_block = (\n",
        "        f\"Total Naranjo Score = {total_score}\\n\\n\"\n",
        "        f\"Interpretation of the Naranjo Score:\\n\"\n",
        "        f\"- ≥ 9 = Definite\\n\"\n",
        "        f\"- 5–8 = Probable\\n\"\n",
        "        f\"- 1–4 = Possible\\n\"\n",
        "        f\"- 0 = Doubtful\\n\\n\"\n",
        "        f\"With a total score of {total_score}, the causality assessment for {drug} causing {event} \"\n",
        "        f\"in this case is **{interpretation}**.\"\n",
        "    )\n",
        "\n",
        "    return header + body + total_block, total_score, interpretation\n",
        "\n",
        "# --- 4) Build narratives for all rows ---\n",
        "records = []\n",
        "for _, row in df_sel.iterrows():\n",
        "    narrative, total_score, interpretation = build_narrative_row(row)\n",
        "    records.append({\n",
        "        \"case_id\": row.get(\"case_id\"),\n",
        "        \"drug\": _safe(row.get(\"drug_name\")),\n",
        "        \"event\": _safe(row.get(\"pt\")),\n",
        "        \"total_score\": int(total_score),\n",
        "        \"interpretation\": interpretation,\n",
        "        \"narrative\": narrative\n",
        "    })\n",
        "\n",
        "hum = pd.DataFrame(records)\n",
        "print(f\"✅ Built narratives for {len(hum)} rows across {hum['case_id'].nunique()} unique case_ids\")\n",
        "\n",
        "# --- 5) Preview example ---\n",
        "if len(hum) > 0:\n",
        "    print(\"\\n🧾 Example Narrative:\\n\")\n",
        "    print(hum.loc[hum.index[0], \"narrative\"])\n",
        "else:\n",
        "    print(\"\\n❌ No narratives generated. Check your input data.\")"
      ],
